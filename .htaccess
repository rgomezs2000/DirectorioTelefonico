<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si entran por /public, redirigir a la raíz del proyecto actual.
    # Funciona igual para dominio raíz, subdominio o subcarpeta.
    RewriteCond %{THE_REQUEST} \s/+(.*/)?public(?:/|\s|\?) [NC]
    RewriteRule ^public/?(.*)$ $1 [R=302,L]

    # Si existe un archivo/carpeta física en /public para esa URL, servirlo sin exponer /public.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}%{REQUEST_URI} -d
    RewriteRule ^(.*)$ public/$1 [L]

    # Para cualquier otra ruta (ej: /login, /api), enviar directo al front controller.
    # Así no dependemos de que Apache procese public/.htaccess.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
