<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si entran por /public, redirigir a la raíz del proyecto (manteniendo subcarpetas).
    RewriteCond %{THE_REQUEST} \s/+(.*/)?public(?:/|\s|\?) [NC]
    RewriteRule ^public/?(.*)$ $1 [R=301,L]

    # Enrutar todo internamente hacia /public sin duplicar prefijo (public/public/...).
    RewriteRule ^(?!public/)(.*)$ public/$1 [L]
</IfModule>
